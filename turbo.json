{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": [
    "NEXT_PUBLIC_FINANCIAL_ALERTS_ORIGIN",
    "INVESTMENTS_ORIGIN",
    "INVESTMENTS_ASSET_PREFIX"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["storybook-static/**"]
    }
  }
}
