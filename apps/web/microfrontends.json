{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "version": "1",
  "applications": {
    "fiap-tech-challenge-web": {
      "packageName": "web",
      "development": {
        "local": 3000,
        "fallback": "fiap-tech-challenge-web.vercel.app"
      }
    },
    "fiap-tech-challenge-investments": {
      "packageName": "investments",
      "assetPrefix": "investments-static",
      "development": {
        "local": 3001,
        "fallback": "fiap-tech-challenge-investments.vercel.app"
      },
      "routing": [
        {
          "paths": [
            "/investments",
            "/investments/:path*",
            "/investments-static/:path*"
          ]
        }
      ]
    }
  }
}
